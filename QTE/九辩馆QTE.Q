[General]
SyntaxVersion=2
BeginHotkey=121
BeginHotkeyMod=0
PauseHotkey=0
PauseHotkeyMod=0
StopHotkey=123
StopHotkeyMod=0
RunOnce=0
EnableWindow=
MacroID=d2c38750-a8f4-492e-bf06-a81c3e936e53
Description=QTE用对比图片法
Enable=0
AutoRun=0
[Repeat]
Type=1
Number=1
[SetupUI]
Type=2
QUI=
[Relative]
SetupOCXFile=
[Comment]

[Attachment]



[Script]

SetSimMode 2

jw1=0
jw2=0
jw3=0
jw4=0


jw0=Plugin.GetSysInfo.GetTime
FindPic 944,355,1757,849,"Attachment:\1号键位位图.bmp",0.9,intA,intB
FindPic 944,355,1757,849,"Attachment:\2号键位位图.bmp",0.9,intC,intD
FindPic 944,355,1757,849,"Attachment:\3号键位位图.bmp",0.9,intE,intF
FindPic 944,355,1757,849,"Attachment:\4号键位位图.bmp",0.9,intG,intH



If intA > 0 And jw0 > jw1 + 650 Then 
    SetSimMode 2
    KeyPress 49, 1
    jw1 = Plugin.GetSysInfo.GetTime
End If

If intC > 0 And jw0 > jw2 + 650 Then 
    SetSimMode 2
    KeyPress 50, 1
    jw2 = Plugin.GetSysInfo.GetTime
End If


If intE > 0 And jw0 > jw3 + 650 Then 
    SetSimMode 2
    KeyPress 51, 1
    jw3 = Plugin.GetSysInfo.GetTime
End If


If intG > 0 And jw0 > jw4 + 650 Then 
    SetSimMode 2
    KeyPress 52, 1
    jw4 = Plugin.GetSysInfo.GetTime
End If
