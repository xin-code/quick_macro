[Script]
SetSimMode 2

//出现对话框 × 的话 按enter跳过
FindPic 1822,819,1913,907,"Attachment:\1.bmp",0.9,intX,intY
If intX > 0 And intY > 0 Then 
KeyPress "Enter", 10
End If

//出现对话框任务卷轴 接任务
FindPic 1211,855,1426,899,"Attachment:\2.bmp",0.9,intX,intY
If intX > 0 And intY > 0 Then 
MoveTo 1284,873
LeftClick 10
End If

//出现对话框选项，点击对话
FindPic 1229,865,1249,880,"Attachment:\3.bmp",0.9,intX,intY
If intX > 0 And intY > 0 Then 
MoveTo 1269,872
LeftClick 10
End If

